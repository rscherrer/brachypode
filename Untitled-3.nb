Notebook[{
Cell["\<\
In this notebook we derive some of the mathematical tools we used to analyze \
the adaptive dynamics of our model. In particular, we derive explicit \
expressions for invasion fitness, for the selection gradient and for the \
curvature of the fitness function. Other derivations are presented in the \
manuscript.\
\>", "Text",
 CellChangeTimes->{{3.8703394110411253`*^9, 3.870339440706661*^9}, {
  3.8703394986627693`*^9, 
  3.870339603660326*^9}},ExpressionUUID->"34ae2cff-0009-4b6c-9f62-\
f03f53520b67"],

Cell[TextData[StyleBox["The model", "Subsection"]], "Text",
 CellChangeTimes->{{3.8702389784401407`*^9, 3.870238980399461*^9}, {
  3.8703393479665327`*^9, 
  3.87033940837577*^9}},ExpressionUUID->"7c7fb9e2-7751-44aa-8903-\
38e3953573b9"],

Cell["The model is as follows:", "Text",
 CellChangeTimes->{{3.870238967347747*^9, 
  3.8702389704586143`*^9}},ExpressionUUID->"4840eeae-65c2-4f2a-a722-\
5747a17a7c00"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Transition", " ", "matrix"}], " ", "*)"}], "\[IndentingNewLine]", 
  
  RowBox[{
   RowBox[{
    RowBox[{"\[CapitalLambda]", "=", 
     RowBox[{"S", ".", "M", ".", "R"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Survival", " ", "matrix"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"S", "=", 
     RowBox[{"(", GridBox[{
        {
         SubscriptBox["s", "1"], "0"},
        {"0", 
         SubscriptBox["s", "2"]}
       }], ")"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Migration", " ", "matrix"}], " ", "*)"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{"M", "=", 
     RowBox[{"(", GridBox[{
        {
         RowBox[{"1", "-", "m"}], "m"},
        {"m", 
         RowBox[{"1", "-", "m"}]}
       }], ")"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Reproduction", " ", "matrix"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"R", "=", 
     RowBox[{"(", GridBox[{
        {
         SubscriptBox["r", "1"], "0"},
        {"0", 
         SubscriptBox["r", "2"]}
       }], ")"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Reproduction", " ", "function"}], " ", "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["r", "1"], "[", "x_", "]"}], ":=", 
     RowBox[{"Piecewise", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           SubscriptBox["r", "max"], ",", 
           RowBox[{
            RowBox[{
             SubscriptBox["w", "1"], "[", "x", "]"}], ">", 
            RowBox[{"c", " ", 
             SubscriptBox["r", "max"]}]}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{
             SubscriptBox["w", "1"], "[", "x", "]"}], "/", "c"}], ",", 
           RowBox[{
            RowBox[{
             SubscriptBox["w", "1"], "[", "x", "]"}], ">", "0"}]}], "}"}]}], 
        "}"}], ",", "0"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["r", "2"], "[", "x_", "]"}], ":=", 
     RowBox[{"Piecewise", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           SubscriptBox["r", "max"], ",", 
           RowBox[{
            RowBox[{
             SubscriptBox["w", "2"], "[", "x", "]"}], ">", 
            RowBox[{"c", " ", 
             SubscriptBox["r", "max"]}]}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{
             SubscriptBox["w", "2"], "[", "x", "]"}], "/", "c"}], ",", 
           RowBox[{
            RowBox[{
             SubscriptBox["w", "2"], "[", "x", "]"}], ">", "0"}]}], "}"}]}], 
        "}"}], ",", "0"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Survival", " ", "function"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["s", "1"], "[", "x_", "]"}], ":=", 
     FractionBox["1", 
      RowBox[{"1", "+", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "a"}], " ", 
         RowBox[{
          SubscriptBox["w", "1"], "[", "x", "]"}]}], "]"}]}]]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["s", "2"], "[", "x_", "]"}], ":=", 
     FractionBox["1", 
      RowBox[{"1", "+", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "a"}], " ", 
         RowBox[{
          SubscriptBox["w", "2"], "[", "x", "]"}]}], "]"}]}]]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Water", " ", "surplus"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["w", "1"], "[", "x_", "]"}], ":=", 
     RowBox[{
      RowBox[{
       SubscriptBox["W", "1"], "/", 
       SubscriptBox["n", "1"]}], "-", "x"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["w", "2"], "[", "x_", "]"}], ":=", 
     RowBox[{
      RowBox[{
       SubscriptBox["W", "2"], "/", 
       SubscriptBox["n", "2"]}], "-", "x"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.870234796764742*^9, 3.870235046355177*^9}, 
