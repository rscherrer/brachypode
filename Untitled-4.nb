 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Example", " ", "parameter", " ", "set"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"pars", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"m", "\[Rule]", "0.5"}], ",", 
      RowBox[{
       SubscriptBox["I", "1"], "\[Rule]", "600"}], ",", 
      RowBox[{
       SubscriptBox["I", "2"], "\[Rule]", "600"}], ",", 
      RowBox[{"c", "\[Rule]", "1"}], ",", 
      RowBox[{"a", "\[Rule]", "5"}], ",", 
      RowBox[{
       SubscriptBox["r", "max"], "\[Rule]", "3"}], ",", 
      RowBox[{
       SubscriptBox["f", "1"], "\[Rule]", "100"}], ",", 
      RowBox[{
       SubscriptBox["f", "2"], "\[Rule]", "400"}], ",", 
      RowBox[{"\[Epsilon]", "\[Rule]", "0.6"}]}], "}"}]}], ";"}]}]], "Input",
