Cell[CellGroupData[{

Cell["Invasion fitness", "Subsection",
 CellChangeTimes->{{3.870239129372693*^9, 
  3.870239133019734*^9}},ExpressionUUID->"f3a69679-aee7-4670-a138-\
3208abe8d1d3"],

Cell["\<\
Next, we compute the invasion fitness of the mutant as the leading eigenvalue \
of the transition matrix.\
\>", "Text",
 CellChangeTimes->{{3.870239096914855*^9, 
  3.8702391137535973`*^9}},ExpressionUUID->"e8a6abff-eed9-403f-acf6-\
4ea8c79f5e1b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Lambda]", "=", 
  RowBox[{
   RowBox[{"\[CapitalLambda]", "//", "Eigenvalues"}], "//", 
   "Last"}]}]], "Input",
 CellChangeTimes->{{3.87023829515451*^9, 3.870238296746562*^9}, {
  3.870238670525199*^9, 3.870238673400285*^9}, {3.870239314970229*^9, 
  3.870239317609297*^9}, {3.871662065038536*^9, 3.871662066865768*^9}},
 CellLabel->"In[24]:=",ExpressionUUID->"93d8549d-3d86-431f-9ecc-7f091d9bb49f"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     SubscriptBox["p", "1"], " ", 
     SubscriptBox["q", "1"]}], "-", 
    RowBox[{"m", " ", 
     SubscriptBox["p", "1"], " ", 
     SubscriptBox["q", "1"]}], "+", 
    RowBox[{
     SubscriptBox["p", "2"], " ", 
     SubscriptBox["q", "2"]}], "-", 
    RowBox[{"m", " ", 
     SubscriptBox["p", "2"], " ", 
     SubscriptBox["q", "2"]}], "+", 
    SqrtBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"-", 
           SubscriptBox["p", "1"]}], " ", 
          SubscriptBox["q", "1"]}], "+", 
         RowBox[{"m", " ", 
          SubscriptBox["p", "1"], " ", 
          SubscriptBox["q", "1"]}], "-", 
         RowBox[{
          SubscriptBox["p", "2"], " ", 
          SubscriptBox["q", "2"]}], "+", 
         RowBox[{"m", " ", 
          SubscriptBox["p", "2"], " ", 
          SubscriptBox["q", "2"]}]}], ")"}], "2"], "-", 
      RowBox[{"4", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SubscriptBox["p", "1"], " ", 
          SubscriptBox["p", "2"], " ", 
          SubscriptBox["q", "1"], " ", 
          SubscriptBox["q", "2"]}], "-", 
         RowBox[{"2", " ", "m", " ", 
          SubscriptBox["p", "1"], " ", 
          SubscriptBox["p", "2"], " ", 
          SubscriptBox["q", "1"], " ", 
          SubscriptBox["q", "2"]}]}], ")"}]}]}]]}], ")"}]}]], "Output",
 CellChangeTimes->{{3.870238297928561*^9, 3.870238304639886*^9}, 
   3.870238352441947*^9, 3.870238624016819*^9, 3.87023867379646*^9, 
   3.870239318947814*^9, 3.8702642704983377`*^9, 3.870335070217842*^9, 
