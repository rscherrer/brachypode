 CellLabel->"Out[24]=",ExpressionUUID->"3568e75e-6130-4586-ad48-97af3ba4f43a"]
}, Open  ]],

Cell["\<\
We now check that the invasion fitness is indeed one when evaluated at the \
resident, i.e. when the mutant is the resident, under a random set of \
parameter values.\
\>", "Text",
 CellChangeTimes->{{3.870239140191349*^9, 3.870239172405699*^9}, {
  3.870240216869279*^9, 
  3.8702402233254223`*^9}},ExpressionUUID->"07eb1e0f-bd5c-4840-b6f9-\
55a6f6547a23"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Example", " ", "parameter", " ", "set"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"pars", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"m", "\[Rule]", "0.5"}], ",", 
      RowBox[{
       SubscriptBox["k", "1"], "\[Rule]", "5000"}], ",", 
      RowBox[{
       SubscriptBox["k", "2"], "\[Rule]", "5000"}], ",", 
      RowBox[{
       SubscriptBox["r", "max"], "\[Rule]", "2"}], ",", 
      RowBox[{"s", "\[Rule]", "0.3"}], ",", 
      RowBox[{"a", "\[Rule]", "5"}], ",", 
      RowBox[{
       SubscriptBox["\[Theta]", "1"], "\[Rule]", "0"}], ",", 
      RowBox[{
       SubscriptBox["\[Theta]", "2"], "\[Rule]", "4"}]}], "}"}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.870239190816792*^9, 3.870239264668635*^9}, 
   3.870239309461257*^9, {3.870239602245571*^9, 3.8702396643244534`*^9}, {
   3.87034063631636*^9, 3.870340645228837*^9}, {3.870405992854703*^9, 
   3.870405993519135*^9}, {3.870406343240634*^9, 3.87040635495156*^9}, {
   3.871663402772365*^9, 3.871663460249386*^9}, {3.871663519710415*^9, 
   3.871663572111466*^9}, 3.8717020483280773`*^9, 3.8717181411892757`*^9},
 CellLabel->"In[25]:=",ExpressionUUID->"76b4086c-cedd-4141-9d63-a4037cc48aaf"],

Cell["\<\
For this we need to find the equilibrium population densities given the \
parameters (we do that numerically).\
\>", "Text",
 CellChangeTimes->{{3.870240233147331*^9, 3.870240246551463*^9}, {
  3.870240279851581*^9, 
  3.870240283769294*^9}},ExpressionUUID->"a4604746-02d0-47d4-bad7-\
0f2a966611f1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Find", " ", "equilibrium", " ", "densities"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"eq", "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            SubscriptBox["n", "1"], ",", 
            SubscriptBox["n", "2"]}], "}"}], "\[Equal]", 
          RowBox[{"\[CapitalLambda]", ".", 
           RowBox[{"{", 
            RowBox[{
             SubscriptBox["n", "1"], ",", 
             SubscriptBox["n", "2"]}], "}"}]}]}], "/.", 
         RowBox[{
          SubscriptBox["p", "1"], "\[Rule]", 
          RowBox[{"p", "[", 
           RowBox[{"x", ",", 
            SubscriptBox["\[Theta]", "1"]}], "]"}]}]}], "/.", 
        RowBox[{
         SubscriptBox["p", "2"], "\[Rule]", 
         RowBox[{"p", "[", 
          RowBox[{"x", ",", 
           SubscriptBox["\[Theta]", "2"]}], "]"}]}]}], "/.", 
       RowBox[{
        SubscriptBox["q", "1"], "\[Rule]", 
        RowBox[{
         SubscriptBox["q", "1"], "[", "x", "]"}]}]}], "/.", 
      RowBox[{
       SubscriptBox["q", "2"], "\[Rule]", 
       RowBox[{
        SubscriptBox["q", "2"], "[", "x", "]"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"sol", "=", 
    RowBox[{"FindRoot", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"eq", "/.", "pars"}], "/.", 
       RowBox[{"x", "\[Rule]", "4"}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          SubscriptBox["n", "1"], ",", "5000"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          SubscriptBox["n", "2"], ",", "5000"}], "}"}]}], "}"}]}], 
     "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.870239363739196*^9, 3.870239406510908*^9}, {
   3.870239437804056*^9, 3.870239460263217*^9}, {3.870239503582671*^9, 
