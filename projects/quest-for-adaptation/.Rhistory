library(tidyverse)
library(brachypoder)
theme_set(theme_classic())
data <- read_trait_mean_data("data/sim-quest-default/")
data %>%
ggplot(aes(x = time, y = z)) +
geom_point()
read_parameters("data/sim-quest-default/")
pars <- read_parameters("data/sim-quest-default/")
pars$stress
data %>%
ggplot(aes(x = time, y = z)) +
geom_point() +
geom_hline(yintercept = pars$stress[1]) +
geom_hline(yintercept = pars$stress[2])
data %>%
ggplot(aes(x = time, y = z)) +
geom_point() +
geom_hline(yintercept = pars$stress[1], color = "darkorange") +
geom_hline(yintercept = pars$stress[2], color = "lightgreen")
data %>%
ggplot(aes(x = time, y = z)) +
geom_hline(yintercept = pars$stress[1], color = "darkorange") +
geom_hline(yintercept = pars$stress[2], color = "lightgreen") +
geom_point()
data %>%
ggplot(aes(x = time, y = z)) +
geom_hline(yintercept = pars$stress[1], color = "#efe58b") +
geom_hline(yintercept = pars$stress[2], color = "#006400") +
geom_point()
plot <- data %>%
ggplot(aes(x = time, y = z)) +
geom_hline(yintercept = pars$stress[1], color = "#efe58b") +
geom_hline(yintercept = pars$stress[2], color = "#006400") +
geom_point()
ggsave("sim-quest-default.png", plot, width = 4, height = 3, dpi = 300)
ggsave("sim-quest-default.png", plot, width = 3, height = 2, dpi = 300)
ggsave("sim-quest-default.png", plot, width = 3, height = 2, dpi = 400)
plot <- data %>%
ggplot(aes(x = time, y = z)) +
geom_hline(yintercept = pars$stress[1], color = "#efe58b") +
geom_hline(yintercept = pars$stress[2], color = "#006400") +
geom_point() +
xlab("Time (generations)") +
ylab("Trait value")
ggsave("sim-quest-default.png", plot, width = 3, height = 2, dpi = 400)
rm(list = ls())
library(tidyverse)
library(brachypoder)
theme_set(theme_classic())
sim_name <- "sim-quest-default"
path <- sprintf("data/%s/", sim_name)
data <- read_trait_mean_data(path)
pars <- read_parameters(path)
plot <- data %>%
ggplot(aes(x = time, y = z)) +
geom_hline(yintercept = pars$stress[1], color = "#efe58b") +
geom_hline(yintercept = pars$stress[2], color = "#006400") +
geom_point() +
xlab("Time (generations)") +
ylab("Trait value")
ggsave(sprintf("%s.png", sim_name), plot, width = 3, height = 2, dpi = 400)
rm(list = ls())
